# ---------------------------------------------------------------------------
# Ileven Radar - Environment Variables
# Copy this file to .env for local development.
# On Railway, set these in the service "Variables" tab instead.
# ---------------------------------------------------------------------------

NODE_ENV=development
LOG_LEVEL=info
PORT=8080

# PostgreSQL connection string.
# Locally: postgres://radar:radar@localhost:5432/ileven_radar
# Railway: provided automatically as DATABASE_URL when you attach a Postgres plugin.
DATABASE_URL=postgres://radar:radar@localhost:5432/ileven_radar

# OpenAI - used by the AI Analysis Agent for extraction, scoring inputs,
# summarization and recommended actions.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Google Programmable Search Engine (Custom Search JSON API).
# Used by the Web Search Agent to monitor keywords across the open web
# (tenders, RFPs, "looking for a developer", funding announcements, etc).
# Create a key at https://console.cloud.google.com/apis/credentials and a
# search engine at https://programmablesearchengine.google.com/
GOOGLE_CSE_API_KEY=your_google_api_key
GOOGLE_CSE_ID=your_search_engine_id

# Telegram Bot - create one with @BotFather on Telegram, copy the token below.
TELEGRAM_BOT_TOKEN=000000000:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Minimum opportunity score (0-100) required before a lead is pushed to
# Telegram subscribers. Leads below this are still stored and searchable
# in the API, just not pushed proactively.
MIN_SCORE_TO_NOTIFY=50

# Cron expression for the discovery cycle. Default: every hour, on the hour.
CRON_SCHEDULE=0 * * * *

# Run one discovery cycle immediately on boot, in addition to the cron schedule.
RUN_ON_STARTUP=true
